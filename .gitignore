# =========================================================
# MERN Stack .gitignore
# =========================================================

# ---------------------------------------------------------
# Dependencies
# ---------------------------------------------------------
node_modules/
jspm_packages/

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------
# Runtime data
# ---------------------------------------------------------
pids
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------
# Environment variables
# ---------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backend env files
server/.env
backend/.env

# Frontend env files
client/.env
frontend/.env

# ---------------------------------------------------------
# Build folders
# ---------------------------------------------------------
dist/
build/
.next/
out/

# React build
client/build/
frontend/build/

# ---------------------------------------------------------
# Coverage / Testing
# ---------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------
# Cache files
# ---------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Vite
vite.svg

# ---------------------------------------------------------
# TypeScript
# ---------------------------------------------------------
*.tsbuildinfo

# ---------------------------------------------------------
# Database / local storage
# ---------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# MongoDB local dump
dump/

# ---------------------------------------------------------
# Uploads / generated content
# ---------------------------------------------------------
uploads/
tmp/
temp/

# ---------------------------------------------------------
# OS generated files
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------
# IDE / Editor files
# ---------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------------------------------------
# Package manager locks (optional)
# Keep ONLY the one you use
# ---------------------------------------------------------
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------
.dockerignore

# ---------------------------------------------------------
# Misc
# ---------------------------------------------------------
*.pem
*.key